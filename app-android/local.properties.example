# Copy to local.properties and fill in your values.
# local.properties is gitignored — never commit it.

# Android SDK path (auto-set by Android Studio; set manually on CI):
# sdk.dir=/Users/yourname/Library/Android/sdk

# LAN IP of the machine running `acis serve` (change per network):
# acis_brain_url=ws://192.168.1.100:8765
