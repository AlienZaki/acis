# Copy to .env and fill in real values.
# Never commit .env — it is gitignored.

# ── Mistral API ──
MISTRAL_API_KEY=

# ── Server ──
ACIS_SERVE_HOST=0.0.0.0
ACIS_SERVE_PORT=8765

# ── Storage ──
ACIS_DB_PATH=~/.acis/acis.db

# ── Models ──
# ASR: voxtral-mini-latest — batch REST endpoint (POST /v1/audio/transcriptions)
# NOTE: voxtral-mini-transcribe-realtime-2602 requires the WebSocket streaming API
ACIS_ASR_MODEL=voxtral-mini-latest
# Cue extraction (~1,020 calls/session): mistral-small-latest (Small 4)
# mistral-medium-latest is now Medium 3.5 at $1.76/session — 11× too expensive
ACIS_CUE_MODEL=mistral-small-latest
# End-of-session summary (1 call/session): Large 3 is still the right choice
# To A/B test reasoning-chain keypoints, swap to: magistral-small-latest
ACIS_SUMMARY_MODEL=mistral-large-latest

# ── Pipeline tuning ──
# Trigger cue extraction after this many new words accumulate
ACIS_CUE_THRESHOLD_WORDS=50

# ── Audio capture (CLI mode) ──
ACIS_AUDIO_SAMPLE_RATE=16000
ACIS_AUDIO_CHUNK_SECS=3.0
